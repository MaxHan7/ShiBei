    "%lld": {
      "comment": "A label displaying a number. The number is automatically translated to the user's current locale.",
      "isCommentAutoGenerated": true
    },
    "%lld / %lld": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld / %2$lld"
          }
        }
      }
    },
    "%lld%%": {
      "comment": "A label showing the percentage of completed knowledge points in a chapter. The argument is the percentage of completed knowledge points.",
      "isCommentAutoGenerated": true
    },
    "%lld/5000": {
      "comment": "A label showing the number of characters in the input field.",
      "isCommentAutoGenerated": true
    },
