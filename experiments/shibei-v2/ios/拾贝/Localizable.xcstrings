    "profile.cloud_sync.body": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ShiBei saves your chapters, notifications, and review progress in the cloud without requiring an account."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拾贝会把你的章节、通知和复习进度保存到云端，不需要注册或登录账号。"
          }
        }
      }
    },
