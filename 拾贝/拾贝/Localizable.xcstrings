      }
    },
    "profile.deleting" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Deleting..." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "正在删除..." } }
      }
    },
    "profile.info.about.p1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "ShiBei turns articles, links, and scattered knowledge into review questions." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "拾贝是一款把文章、链接和碎片知识转化为复习题的 iOS App。" } }
      }
    },
    "profile.info.about.p2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This version focuses on real content generation, review, and source-based explanations." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前版本重点打磨真实内容生成、复习和来源解释，让你更轻地把读过的内容变成可回顾的知识。" } }
      }
    },
    "profile.info.account.p1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This version stores data with an anonymous device identity. No account or sign-in is required." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "当前版本使用匿名设备身份保存数据，不需要注册或登录账号。" } }
      }
    },
    "profile.info.account.p2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The anonymous identity only separates your chapters, notifications, review records, and feedback. If account support is added later, data migration will be handled then." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "匿名设备身份只用于区分你的章节、通知、复习记录和题目反馈。后续如果提供账号系统，会再提供数据迁移方案。" } }
      }
    },
    "profile.info.notifications.p1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "ShiBei sends system notifications when content generation succeeds or fails, so you can return to the chapter." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "拾贝会在内容生成完成或失败时发送系统通知，帮助你回到对应章节继续复习。" } }
      }
    },
    "profile.info.notifications.p2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "If system notifications are off, in-app notifications still show results. Success notifications archive after opening; failure notifications remain until handled or removed." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "如果你没有开启系统通知，仍然可以在 App 内通知页查看生成结果。成功通知打开后会自动归档，失败通知会保留到你处理或手动移除。" } }
      }
    },
    "profile.info.privacy.p1" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Text, article links, and generated results you submit are sent to ShiBei Cloud to extract points, generate questions, and save review progress." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "你提交的文字、文章链接和生成结果会发送到拾贝云端，用于提取知识点、生成题目和保存复习进度。" } }
      }
    },
    "profile.info.privacy.p2" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "During generation, content may be sent to third-party AI model services. ShiBei does not publicly show your content to other users." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "生成过程中，内容可能会被发送给第三方 AI 模型服务处理。拾贝不会把你的内容公开展示给其他用户。" } }
      }
    },
    "profile.info.privacy.p3" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The server stores chapters, questions, notifications, review records, and question feedback. You can delete data for this anonymous device from Profile." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "服务器会保存章节、题目、通知、复习记录和题目反馈。你可以在“我的”页删除当前匿名设备下的数据。" } }
      }
    },
