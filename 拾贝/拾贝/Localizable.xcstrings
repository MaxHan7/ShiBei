    "profile.delete_data.alert.message" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "This removes chapters, notifications, review records, and feedback under this anonymous device. This cannot be undone." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "删除后，当前匿名设备下的章节、通知、复习记录和反馈都会被移除。这个操作无法撤销。" } }
      }
    },
    "profile.delete_data.alert.title" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete my data?" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "删除我的数据？" } }
      }
    },
    "profile.delete_my_data" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Delete my data" } },
