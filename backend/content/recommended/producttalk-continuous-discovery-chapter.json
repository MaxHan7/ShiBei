            },
            {
              "id": "R2",
              "text": "交付（Delivery）"
            },
            {
              "id": "R3",
              "text": "持续发现（Continuous Discovery）"
            }
          ],
          "pairs": [
            {
              "leftId": "L1",
              "rightId": "R1"
            },
            {
              "leftId": "L2",
              "rightId": "R2"
            },
            {
              "leftId": "L3",
              "rightId": "R3"
            }
